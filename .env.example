# Step 1 - Tool Servers
DESTINATION_TOOLS_PORT=8001
TRANSPORT_TOOLS_PORT=8002
PRICING_DB_TOOLS_PORT=8003

# SQLite database path for pricing-db-tools
TRAVEL_DB_PATH=data/travel.db

# Step 2+ - Agent runtime
# Set ONE provider.
LLM_PROVIDER=openai

# OpenAI config (if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic config (if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional override used by itinerary tools.
DESTINATION_TOOLS_URL=http://127.0.0.1:8001/mcp
